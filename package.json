{
  "name": "elementa-education",
  "version": "1.0.0",
  "description": "Elementa Education - Tutoring Centre Management System",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create elementa-db",
    "db:init": "wrangler d1 execute elementa-db --file=schema.sql",
    "db:init:remote": "wrangler d1 execute elementa-db --remote --file=schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
